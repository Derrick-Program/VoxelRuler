import { SideBar, Footer } from "components/index.slint";
import { Assets } from "@assets";
import { AppTheme } from "@theme";

export global AppData {
    in property <string> version: "v0.0.1";
}

export component MainApp inherits Window {
    min-width: 800px;
    min-height: 580px;
    preferred-width: 800px;
    preferred-height: 580px;
    // width: 800px;
    // height: 580px;
    title: "VoxelRuler";
    icon: Assets.logo;
    VerticalLayout {
        spacing: 0;
        app := HorizontalLayout {
            vertical-stretch: 1;
            SideBar { }
            Rectangle {
                // background: red;
                horizontal-stretch: 1;
                vertical-stretch: 1;
            }
        }

        footer := Footer {
            vertical-stretch: 0;
            version: AppData.version;
        }
    }
}
