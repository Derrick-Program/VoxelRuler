import { AppTheme } from "@theme";
import { CheckBox, ListView } from "std-widgets.slint";

export struct AccountRow {
    checked: bool,
    username: string,
    status: string,
}

export component AccountTable inherits VerticalLayout {
    in property <[AccountRow]> rows: [];
    in-out property <int> selected-index: -1;

    spacing: 0;

    // Header
    Rectangle {
        height: 36px;
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            spacing: 8px;

            Rectangle { width: 20px; }

            Text {
                horizontal-stretch: 4;
                text: @tr("Username");
                color: AppTheme.colors.muted-foreground;
                font-size: AppTheme.font-size-base;
                vertical-alignment: center;
            }
            Text {
                horizontal-stretch: 1;
                text: @tr("Status");
                color: AppTheme.colors.muted-foreground;
                font-size: AppTheme.font-size-base;
                vertical-alignment: center;
            }
        }
    }

    Rectangle {
        height: 1px;
        background: AppTheme.colors.border;
    }

    ListView {
        vertical-stretch: 1;

        for row[i] in root.rows: Rectangle {
            height: 40px;
            background: i == root.selected-index
                ? AppTheme.colors.muted
                : transparent;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;

                CheckBox {
                    width: 20px;
                    enabled: false;
                    checked: row.checked;
                }
                Text {
                    horizontal-stretch: 4;
                    text: row.username;
                    color: AppTheme.colors.foreground;
                    font-size: AppTheme.font-size-base;
                    vertical-alignment: center;
                    wrap: no-wrap;
                    overflow: elide;
                }
                Text {
                    horizontal-stretch: 1;
                    text: row.status;
                    color: AppTheme.colors.foreground;
                    font-size: AppTheme.font-size-base;
                    vertical-alignment: center;
                }
            }

            TouchArea {
                clicked => { root.selected-index = i; }
            }
        }
    }
}
