import { Palette } from "std-widgets.slint";
export struct ThemeColors {
    background: color,
    foreground: color,
    card: color,
    card-foreground: color,
    primary: color,
    primary-foreground: color,
    secondary: color,
    secondary-foreground: color,
    accent: color,
    accent-foreground: color,
    destructive: color,
    destructive-foreground: color,
    muted: color,
    muted-foreground: color,
    border: color,
    input-bg: color,
    sidebar: color,
    sidebar-border: color,
    sidebar-foreground: color,
    sidebar-accent: color,
}

export global AppTheme {
    in-out property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;

    out property <color> mc-green: #4CAF50;
    out property <color> mc-grass: #7CB342;
    out property <color> mc-dirt: #8D6E63;
    out property <color> mc-stone: #78909C;
    out property <color> mc-diamond: #00BCD4;

    out property <ThemeColors> colors: {
        background: root.is-dark ? #111111 : #1a1a1a,
        foreground: #e0e0e0,
        card: root.is-dark ? #181818 : #2a2a2a,
        card-foreground: #e0e0e0,
        primary: root.mc-grass,
        primary-foreground: #ffffff,
        secondary: root.is-dark ? #242424 : #424242,
        secondary-foreground: #e0e0e0,
        accent: root.mc-diamond,
        accent-foreground: #ffffff,
        destructive: #f44336,
        destructive-foreground: #ffffff,
        muted: root.is-dark ? #2a2a2a : #333333,
        muted-foreground: #9e9e9e,
        border: root.is-dark ? rgba(255, 255, 255, 0.08) : rgba(255, 255, 255, 0.12),
        input-bg: root.is-dark ? #242424 : #333333,
        sidebar: root.is-dark ? #0f0f0f : #1E1E1E,
        sidebar-border: root.is-dark ? rgba(255, 255, 255, 0.08) : rgba(255, 255, 255, 0.12),
        sidebar-foreground: #e0e0e0,
        sidebar-accent: #2a2a2a
    };

    out property <length> radius-base: 10px; // 對應 0.5rem
    out property <length> radius-sm: root.radius-base - 4px;
    out property <length> radius-md: root.radius-base - 2px;
    out property <length> radius-lg: root.radius-base;
    out property <length> radius-xl: root.radius-base + 4px;

    out property <length> font-size-base: 16px;
    out property <length> h1: 24px; // 對應 text-2xl
    out property <length> h2: 20px; // 對應 text-xl
    out property <length> h3: 18px; // 對應 text-lg
    out property <length> h4: 16px; // 對應 text-base
    
    out property <int> font-weight-medium: 500;
    out property <int> font-weight-normal: 400;

    out property <color> chart-1: oklch(0.646, 0.222, 41.116);
    out property <color> chart-2: oklch(0.6, 0.118, 184.704);
    out property <color> chart-3: oklch(0.398, 0.07, 227.392);
    out property <color> chart-4: oklch(0.828, 0.189, 84.429);
    out property <color> chart-5: oklch(0.769, 0.188, 70.08);

    out property <color> base-border: #ffffff;
    out property <color> border: root.is-dark ? root.base-border.with-alpha(0.08) : root.base-border.with-alpha(0.12);
}
