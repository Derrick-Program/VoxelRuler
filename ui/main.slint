import { SideBar, Footer, Pages } from "components/index.slint";
import { Assets } from "@assets";
import { AppTheme } from "@theme";
import { AppData, InstanceLogic, AppLogic } from "@global";

export { AppData, InstanceLogic, AppLogic }
export component MainApp inherits Window {
    min-width: 800px;
    min-height: 600px;
    preferred-width: 800px;
    preferred-height: 600px;
    title: "VoxelRuler";
    icon: Assets.logo;

    VerticalLayout {
        spacing: 0;
        app := HorizontalLayout {
            vertical-stretch: 1;
            sidebar := SideBar {
                tab-changed(id) => AppLogic.sidebar_change(id);
            }

            pages := Pages {
                active-tab: sidebar.active-tab;
            }
        }

        footer := Footer {
            vertical-stretch: 0;
            version: AppData.version;
        }
    }
}
