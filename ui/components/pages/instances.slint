import { AppTheme } from "@theme";
import { Assets } from "@assets";
import { ScrollView } from "std-widgets.slint";

export struct InstanceData {
    id: string,
    name: string,
    version: string,
    mod_loader: string,
    last_played: string,
    play_time: string,
    image: image,
    status: string, // "ready", "running", "updating"
}

export component InstanceCard inherits Rectangle {
    in property <InstanceData> data;

    callback launch(string);
    callback open_settings(string);

    height: 260px;
    background: transparent;
    horizontal-stretch: 1;

    ta := TouchArea { }

    content_root := Rectangle {
        width: 100%;
        height: 100%;
        background: @linear-gradient(180deg, #2a2a2a 0%, #1a1a1a 100%);
        border-radius: 12px;
        border-width: 1px;
        border-color: ta.has-hover ? #76bc51.with-alpha(0.5) : #ffffff.with-alpha(0.1);
        clip: true;

        y: ta.has-hover ? -4px : 0px;
        animate y {
            duration: 150ms;
            easing: ease-out;
        }
        animate border-color { duration: 200ms; }

        VerticalLayout {
            Rectangle {
                vertical-stretch: 2;
                background: #1a1a1a;
                height: 50%;
                Image {
                    source: root.data.image;
                    width: 100%;
                    height: 100%;
                    image-fit: cover;
                    opacity: ta.has-hover ? 1.0 : 0.8;
                    animate opacity { duration: 300ms; }
                }

                HorizontalLayout {
                    padding: 8px;
                    alignment: space-between;
                    HorizontalLayout {
                        spacing: 4px;
                        if (root.data.mod_loader != ""): Rectangle {
                            background: black.with-alpha(0.6);
                            border-radius: 4px;
                            height: 18px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: root.data.mod_loader;
                                    font-size: 10px;
                                    color: white;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle {
                            background: black.with-alpha(0.6);
                            border-radius: 4px;
                            height: 18px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: root.data.version;
                                    font-size: 10px;
                                    color: white;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    sett-rect := Rectangle {
                        width: 24px;
                        height: 24px;
                        background: sett-ta.has-hover ? white.with-alpha(0.2) : transparent;
                        border-radius: 4px;
                        Image {
                            source: Assets.setting;
                            width: 14px;
                            colorize: white;
                        }

                        sett-ta := TouchArea {
                            clicked => {
                                root.open_settings(root.data.id)
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                vertical-stretch: 1;
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 10px;
                height: 50%;
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: root.data.status == "running" ? #50fa7b : (root.data.status == "updating" ? #8be9fd : #6272a4);
                        }
                    }

                    Text {
                        text: root.data.name;
                        color: white;
                        font-size: 16px;
                        font-weight: 700;
                        overflow: elide;
                    }
                }

                Text {
                    text: @tr("Last played: {}", root.data.last_played);
                    color: #aaa;
                    font-size: 12px;
                }

                if (root.data.play_time != ""): Text {
                    text: @tr("Total play time: {}", root.data.play_time);
                    color: #aaa;
                    font-size: 12px;
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                btn := Rectangle {
                    min-height: 32px;
                    background: btn-ta.pressed ? #5a9e3f : (btn-ta.has-hover ? #76bc51 : #67ab44.with-alpha(0.2));
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #67ab44.with-alpha(0.5);

                    HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        Image {
                            source: Assets.play;
                            width: 24px;
                            colorize: btn-ta.has-hover ? white : #67ab44;
                        }

                        Text {
                            text: @tr("Start Game");
                            color: btn-ta.has-hover ? white : #67ab44;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            font-size: 16px;
                            font-weight: 700;
                        }
                    }

                    btn-ta := TouchArea {
                        clicked => {
                            root.launch(root.data.id)
                        }
                    }
                }
            }
        }
    }
}




component AddInstance inherits Rectangle {
    in property <string> text;
    in property <image> icon;
    in property <bool> is_primary: true;
    callback clicked;

    background: ta.pressed ? (is_primary ? #5a9e3f : #454545) : (ta.has-hover ? (is_primary ? #76bc51 : #3d3d3d) : (is_primary ? #67ab44 : #333333));
    border-radius: 8px;
    height: 36px;
    width: layout.preferred-width + 24px;

    ta := TouchArea {
        clicked => {
            root.clicked()
        }
    }

    layout := HorizontalLayout {
        spacing: 8px;
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        alignment: center;
        if (root.icon.width > 0): Image {
            width: 20px;
            height: 100%;
            image-fit: contain;
            vertical-alignment: center;
            horizontal-alignment: center;
            source: root.icon;
            colorize: white;
        }
        Text {
            text: root.text;
            color: white;
            font-size: 16px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

component Search inherits Rectangle {
    height: 100%;
    border-radius: AppTheme.radius-lg;
    border-color: #ffffff.with-alpha(0.6);
    border-width: 1px;
    in-out property <string> search-text <=> ti.text;
    callback _clear-focus();
    _clear-focus => {
        ti.clear-focus();
    }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        s-i := Rectangle {
            width: 24px;
            height: 100%;
            Image {
                source: Assets.search;
                width: 20px;
                height: 20px;
                vertical-alignment: center;
                horizontal-alignment: center;
                image-fit: contain;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            if (!ti.has-focus && ti.text == ""): Text {
                text: @tr("Search instances...");
                color: white.with-alpha(0.5);
                vertical-alignment: center;
                horizontal-alignment: left;
                font-size: 16px;
                width: 100%;
            }

            ti := TextInput {
                width: 100%;
                height: 100%;
                color: white;
                font-size: 16px;
                vertical-alignment: center;
                accepted => {
                    root._clear-focus();
                    debug(ti.text)
                }
            }
        }
    }
}

export component Instances inherits Rectangle {
    background: AppTheme.colors.background;
    width: 100%;
    height: 100%;
    property <length> min-card-width: 180px;
    property <int> dynamic-column-count: Math.max(1, Math.floor(self.width / root.min-card-width));
    property <length> calculated-card-width: (self.width - (grid.spacing * (root.dynamic-column-count - 1)) - 40px) / root.dynamic-column-count;
    in property <[InstanceData]> instance_list: [
        {
            id: "1",
            name: "Example Instance 1",
            version: "1.20.4",
            mod_loader: "Fabric",
            last_played: "2024-06-01",
            play_time: "12h 34m",
            image: Assets.logo,
            status: "ready"
        },
        {
            id: "2",
            name: "Example Instance 2 with a very long name that should be truncated",
            version: "1.19.2",
            mod_loader: "",
            last_played: "2024-05-28",
            play_time: "",
            image: Assets.logo,
            status: "running"
        },
        {
            id: "3",
            name: "Example Instance 3",
            version: "1.18.1",
            mod_loader: "Forge",
            last_played: "2024-04-15",
            play_time: "5h 20m",
            image: Assets.logo,
            status: "updating"
        },
        {
            id: "4",
            name: "Example Instance 4",
            version: "1.17.1",
            mod_loader: "Fabric",
            last_played: "2024-03-10",
            play_time: "2h 45m",
            image: Assets.logo,
            status: "ready"
        },
        {
            id: "5",
            name: "Example Instance 5",
            version: "1.16.5",
            mod_loader: "",
            last_played: "2024-02-20",
            play_time: "10h 15m",
            image: Assets.logo,
            status: "ready"
        },
        {
            id: "6",
            name: "Example Instance 6",
            version: "1.15.2",
            mod_loader: "Forge",
            last_played: "2024-01-05",
            play_time: "8h 50m",
            image: Assets.logo,
            status: "ready"
        },
        {
            id: "7",
            name: "Example Instance 7",
            version: "1.14.4",
            mod_loader: "Fabric",
            last_played: "2023-12-12",
            play_time: "15h 30m",
            image: Assets.logo,
            status: "ready"
        },
        {
            id: "8",
            name: "Example Instance 8",
            version: "1.13.2",
            mod_loader: "",
            last_played: "2023-11-01",
            play_time: "3h 40m",
            image: Assets.logo,
            status: "ready"
        }
    ];
    callback new_instance();
    callback launch_instance(string);
    callback open_instance_settings(string);
    new_instance => {
        debug("Create new instance");
    }
    launch_instance(id) => {
        debug("Launch instance with id: " + id);
    }
    open_instance_settings(id) => {
        debug("Open settings for instance with id: " + id);
    }

    TouchArea {
        clicked => {
            s-c._clear-focus();
        }
    }

    VerticalLayout {
        Rectangle {
            VerticalLayout {
                padding-top: 20px;
                padding-left: 10px;
                padding-right: 10px;
                padding-bottom: 20px;
                spacing: 10px;
                height: 140px;
                VerticalLayout {
                    height: 50px;
                    HorizontalLayout {
                        alignment: space-between;
                        height: 50px;
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            Image {
                                source: Assets.cube;
                                width: 100%;
                                height: 100%;
                                image-fit: contain;
                            }
                        }

                        Text {
                            text: @tr("My Instances");
                            font-size: 30px;
                            font-weight: 700;
                            color: AppTheme.colors.foreground;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        AddInstance {
                            text: @tr("Create");
                            icon: Assets.plus;
                            clicked => root.new_instance();
                        }
                    }
                }

                VerticalLayout {
                    height: 50px;
                    s-c := Search { }
                }
            }
        }

        ScrollView {
            viewport-width: parent.width;
            vertical-stretch: 1;
            viewport-height: grid.preferred-height;
            grid := GridLayout {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 20px;
                padding-bottom: 40px;

                for data[i] in root.instance_list: InstanceCard {
                    width: root.calculated-card-width;
                    row: Math.floor(i / root.dynamic-column-count);
                    col: Math.mod(i, root.dynamic-column-count);
                    data: data;
                    launch(id) => {
                        root.launch_instance(id)
                    }
                    open_settings(id) => {
                        root.open_instance_settings(id)
                    }
                }
            }
        }
    }
}
