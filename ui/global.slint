import { AppTheme } from "@theme";
import { Assets } from "@assets";

export enum SideTabId {
    home,
    instances,
    mods,
    downloads,
    account,
    settings
}

export struct AccountRow {
    checked: bool,
    username: string,
    status: string,
}

export struct InstanceData {
    id: string,
    name: string,
    version: string,
    mod_loader: string,
    last_played: string,
    play_time: string,
    image: image,
    status: string, // "ready", "running", "updating"
}

export global AppData {
    in property <string> version: @tr("version not found");
}

export global AppLogic {
    callback check_for_updates();
    callback start_download();
    callback sidebar_change(SideTabId);

    check_for_updates => {
        debug("Checking for updates...");
    }
    start_download => {
        debug("Starting download...");
    }

    sidebar_change(id) => {
        debug(id);
    }
}

