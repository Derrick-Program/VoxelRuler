import { AppTheme } from "@theme";
export component SideButton inherits Rectangle {
    in property <image> icon;
    in property <string> text;
    in property <bool> selected: false;
    in property <bool> show-indicator: true;
    callback clicked();

    height: 30px;
    background: transparent;
    border-radius: AppTheme.radius-base;

    ta := TouchArea {
        clicked => root.clicked();
    }

    HorizontalLayout {
        padding-left: 10px;
        spacing: 25px;
        alignment: root.icon.width > 0 ? start : center;
        if (root.icon.width > 0): icon-container := Rectangle {
            width: 24px;
            height: 24px;
            y: (parent.height - self.height) / 2;
            Image {
                source: root.icon;
                width: 100%;
                height: 100%;
                image-fit: contain;
                vertical-alignment: center;
                colorize: root.selected ? AppTheme.colors.primary : AppTheme.colors.foreground;
                opacity: root.selected ? 1.0 : 0.7;
            }
        }

        button-text := Text {
            text: root.text;
            font-size: AppTheme.font-size-base;
            vertical-alignment: center;
            color: AppTheme.colors.sidebar-foreground;
            opacity: 0.7;
            font-weight: AppTheme.font-weight-medium;
        }
    }

    if root.selected && root.show-indicator: Rectangle {
        width: 4px;
        height: 16px;
        background: AppTheme.colors.primary;
        border-radius: 10px;
        x: parent.width - self.width - 8px;
        y: (parent.height - self.height) / 2;
    }
    states [
        active when root.selected: {
            background: AppTheme.colors.primary.with-alpha(0.06);
            button-text.color: AppTheme.colors.primary;
            button-text.opacity: 1.0;
        }
        hover when ta.has-hover: {
            background: AppTheme.colors.sidebar-accent;
            button-text.color: AppTheme.colors.sidebar-foreground;
            button-text.opacity: 1.0;
        }
    ]
    animate background { duration: 150ms; }
}
