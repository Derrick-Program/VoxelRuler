import { AppTheme } from "@theme";
import { Assets } from "@assets";
import { ScrollView } from "std-widgets.slint";
import { ModLogic, ModData } from "@global";

component ModSearch inherits Rectangle {
    in property <float> scale: 1.0;

    height: 44px;
    border-radius: AppTheme.radius-lg;
    border-color: #ffffff.with-alpha(0.6);
    border-width: 1px;
    callback _clear-focus();
    _clear-focus => { ti.clear-focus(); }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        Rectangle {
            width: 24px;
            height: 100%;
            Image {
                source: Assets.search;
                width: 20px;
                height: 20px;
                vertical-alignment: center;
                horizontal-alignment: center;
                image-fit: contain;
            }
        }
        Rectangle {
            horizontal-stretch: 1;
            if (!ti.has-focus && ti.text == ""): Text {
                text: @tr("Search mods...");
                color: white.with-alpha(0.5);
                vertical-alignment: center;
                horizontal-alignment: left;
                font-size: 16px * root.scale;
                width: 100%;
            }
            ti := TextInput {
                text <=> ModLogic.search_text;
                width: 100%;
                height: 100%;
                color: white;
                font-size: 16px * root.scale;
                vertical-alignment: center;
                accepted => {
                    ModLogic.search_changed(self.text);
                    root._clear-focus();
                }
            }
        }
    }
}

component ModItem inherits Rectangle {
    in property <ModData> data;
    in property <bool> selected;
    in property <float> scale: 1.0;
    callback clicked();

    height: 68px;
    background: selected
        ? AppTheme.colors.secondary
        : (ta.has-hover ? AppTheme.colors.muted : transparent);
    border-radius: AppTheme.radius-md;
    border-width: selected ? 1px : 0px;
    border-color: AppTheme.colors.primary.with-alpha(0.5);
    animate background { duration: 150ms; }

    ta := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 10px;
        alignment: center;

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 4px;
            Text {
                text: data.name;
                color: data.enabled ? AppTheme.colors.foreground : AppTheme.colors.muted-foreground;
                font-size: 16px * root.scale;
                font-weight: 600;
                overflow: elide;
            }
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                if (data.mod_loader != ""): Rectangle {
                    background: AppTheme.colors.muted;
                    border-radius: 3px;
                    height: 18px;
                    HorizontalLayout {
                        padding-left: 5px;
                        padding-right: 5px;
                        Text {
                            text: data.mod_loader;
                            font-size: 12px * root.scale;
                            color: AppTheme.colors.muted-foreground;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle {
                    background: AppTheme.colors.muted;
                    border-radius: 3px;
                    height: 18px;
                    HorizontalLayout {
                        padding-left: 5px;
                        padding-right: 5px;
                        Text {
                            text: data.version;
                            font-size: 12px * root.scale;
                            color: AppTheme.colors.muted-foreground;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

    }
}

component ModDetail inherits Rectangle {
    in property <ModData> data;
    in property <float> scale: 1.0;

    background: AppTheme.colors.card;
    border-radius: AppTheme.radius-lg;
    border-width: 1px;
    border-color: AppTheme.colors.border;

    VerticalLayout {
        padding: 20px;
        spacing: 14px;

        VerticalLayout {
            spacing: 4px;
            Text {
                text: data.name;
                color: AppTheme.colors.foreground;
                font-size: 22px * root.scale;
                font-weight: 700;
                overflow: elide;
            }
            Text {
                text: @tr("by {}", data.author);
                color: AppTheme.colors.muted-foreground;
                font-size: 14px * root.scale;
            }
        }

        Rectangle {
            height: 1px;
            background: AppTheme.colors.border;
        }

        HorizontalLayout {
            spacing: 20px;
            VerticalLayout {
                spacing: 2px;
                Text {
                    text: @tr("Version");
                    color: AppTheme.colors.muted-foreground;
                    font-size: 13px * root.scale;
                }
                Text {
                    text: data.version;
                    color: AppTheme.colors.foreground;
                    font-size: 15px * root.scale;
                    font-weight: 500;
                }
            }
            VerticalLayout {
                spacing: 2px;
                Text {
                    text: @tr("Loader");
                    color: AppTheme.colors.muted-foreground;
                    font-size: 13px * root.scale;
                }
                Text {
                    text: data.mod_loader != "" ? data.mod_loader : @tr("Vanilla");
                    color: AppTheme.colors.foreground;
                    font-size: 15px * root.scale;
                    font-weight: 500;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: AppTheme.colors.border;
        }

        VerticalLayout {
            vertical-stretch: 1;
            spacing: 6px;
            Text {
                text: @tr("Description");
                color: AppTheme.colors.muted-foreground;
                font-size: 14px * root.scale;
                font-weight: 600;
            }
            ScrollView {
                vertical-stretch: 1;
                viewport-height: desc-text.preferred-height;
                desc-text := Text {
                    text: data.description;
                    color: AppTheme.colors.foreground;
                    font-size: 15px * root.scale;
                    wrap: word-wrap;
                    width: parent.viewport-width;
                }
            }
        }
    }
}

export component Mods inherits Rectangle {
    background: AppTheme.colors.background;
    width: 100%;
    height: 100%;

    property <float> text-scale: max(1.0, min(1.5, root.width / 800px));

    TouchArea {
        clicked => { search-c._clear-focus(); }
    }

    VerticalLayout {
        VerticalLayout {
            vertical-stretch: 0;
            padding-top: 20px;
            padding-left: 10px;
            padding-right: 10px;
            padding-bottom: 16px;
            spacing: 10px;

            HorizontalLayout {
                alignment: space-between;
                height: 50px;
                Rectangle {
                    width: 40px;
                    height: 40px;
                    Image {
                        source: Assets.cube;
                        width: 100%;
                        height: 100%;
                        image-fit: contain;
                    }
                }
                Text {
                    text: @tr("Mods");
                    font-size: 28px;
                    font-weight: 700;
                    color: AppTheme.colors.foreground;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                Rectangle { width: 40px; }
            }

            search-c := ModSearch { 
                scale: 1.0;
            }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            padding-left: 10px;
            padding-right: 10px;
            padding-bottom: 10px;
            spacing: 10px;

            ScrollView {
                horizontal-stretch: 1;
                min-width: 220px; 
                max-width: 350px; 
                
                viewport-height: mod-list.preferred-height;

                mod-list := VerticalLayout {
                    spacing: 2px;
                    padding: 4px;
                    for mod[i] in ModLogic.mod_list: ModItem {
                        data: mod;
                        selected: ModLogic.selected_index == i;
                        scale: root.text-scale;
                        clicked => { ModLogic.selected_index = i; }
                    }
                }
            }

            Rectangle {
                width: 1px;
                background: AppTheme.colors.border;
            }

            ModDetail {
                horizontal-stretch: 2;
                min-width: 300px;
                scale: root.text-scale;

                visible: ModLogic.mod_list.length > 0;
                data: ModLogic.mod_list.length > 0 ? ModLogic.mod_list[ModLogic.selected_index] : {
                    id: "", name: "", author: "", version: "", mod_loader: "", description: "", enabled: false
                };
            }
        }
    }
}