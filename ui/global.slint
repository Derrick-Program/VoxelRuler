import { AppTheme } from "@theme";
import { Assets } from "@assets";
export struct InstanceData {
    id: string,
    name: string,
    version: string,
    mod_loader: string,
    last_played: string,
    play_time: string,
    image: image,
    status: string, // "ready", "running", "updating"
}

export global AppData {
    in property <string> version: "version not found";
}

