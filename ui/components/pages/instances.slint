import { AppTheme } from "@theme";
import { Assets } from "@assets";
import { ScrollView } from "std-widgets.slint";
import { InstanceLogic, InstanceData } from "@global";

export component InstanceCard inherits Rectangle {
    in property <InstanceData> data;

    height: 260px;
    background: transparent;
    horizontal-stretch: 1;

    ta := TouchArea { }

    property <bool> is-valid: root.data.id != "";

    content_root := Rectangle {
        width: 100%;
        height: 100%;
        background: @linear-gradient(180deg, #2a2a2a 0%, #1a1a1a 100%);
        border-radius: 12px;
        border-width: 1px;
        border-color: ta.has-hover ? #76bc51.with-alpha(0.5) : #ffffff.with-alpha(0.1);
        clip: true;

        y: (ta.has-hover && root.is-valid) ? -4px : 0px;
        animate y {
            duration: 150ms;
            easing: ease-out;
        }
        animate border-color { duration: 200ms; }

        VerticalLayout {
            Rectangle {
                vertical-stretch: 2;
                background: #1a1a1a;
                height: 50%;
                Image {
                    source: root.is-valid ? root.data.image : @image-url("");
                    width: 100%;
                    height: 100%;
                    image-fit: cover;
                    opacity: ta.has-hover ? 1.0 : 0.8;
                    animate opacity { duration: 300ms; }
                }

                HorizontalLayout {
                    padding: 8px;
                    alignment: space-between;
                    HorizontalLayout {
                        spacing: 4px;
                        if (root.is-valid && root.data.mod_loader != "" && root.data.mod_loader != "None"): Rectangle {
                            background: black.with-alpha(0.6);
                            border-radius: 4px;
                            height: 18px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: root.data.mod_loader;
                                    font-size: 10px;
                                    color: white;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        if (root.is-valid): Rectangle {
                            background: black.with-alpha(0.6);
                            border-radius: 4px;
                            height: 18px;
                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                Text {
                                    text: root.data.version;
                                    font-size: 10px;
                                    color: white;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 4px;

                        if (root.is-valid && root.data.status == "running"): log-rect := Rectangle {
                            width: 24px;
                            height: 24px;
                            background: log-ta.has-hover ? white.with-alpha(0.2) : transparent;
                            border-radius: 4px;
                            Image {
                                source: Assets.log;
                                width: 14px;
                                colorize: #8be9fd;
                            }

                            log-ta := TouchArea {
                                clicked => {
                                    if (root.is-valid) {
                                        InstanceLogic.open-log(root.data.id)
                                    }
                                }
                            }
                        }

                        if (root.is-valid): sett-rect := Rectangle {
                            width: 24px;
                            height: 24px;
                            background: sett-ta.has-hover ? white.with-alpha(0.2) : transparent;
                            border-radius: 4px;
                            Image {
                                source: Assets.setting;
                                width: 14px;
                                colorize: white;
                            }

                            sett-ta := TouchArea {
                                clicked => {
                                    if (root.is-valid) {
                                        InstanceLogic.open_instance_settings(root.data.id)
                                    }
                                }
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                vertical-stretch: 1;
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 8px;
                height: 50%;
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            // background: root.data.status == "running" ? #50fa7b : (root.data.status == "updating" ? #8be9fd : #6272a4);
                            background: !root.is-valid ? #6272a4 : (root.data.status == "running" ? #50fa7b : (root.data.status == "updating" ? #8be9fd : #6272a4));
                        }
                    }

                    Text {
                        text: root.is-valid ? root.data.name : "";
                        color: white;
                        font-size: 16px;
                        font-weight: 700;
                        overflow: elide;
                    }
                }

                Text {
                    text: root.is-valid ? @tr("Last played: {}", root.data.last_played) : "";
                    color: #aaa;
                    font-size: 10px;
                }

                if (root.is-valid && root.data.play_time != ""): Text {
                    text: @tr("Total play time: {}", root.data.play_time);
                    color: #aaa;
                    font-size: 10px;
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                if (root.is-valid): btn := Rectangle {
                    property <bool> is-running: root.data.status == "running";
                    height: 32px;
                    background: is-running ? (btn-ta.pressed ? #b03030 : (btn-ta.has-hover ? #e05050 : #c04040.with-alpha(0.2))) : (btn-ta.pressed ? #5a9e3f : (btn-ta.has-hover ? #76bc51 : #67ab44.with-alpha(0.2)));
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: is-running ? #c04040.with-alpha(0.5) : #67ab44.with-alpha(0.5);

                    HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        Image {
                            source: is-running ? Assets.stop : Assets.play;
                            width: 24px;
                            colorize: btn-ta.has-hover ? white : (is-running ? #c04040 : #67ab44);
                        }

                        Text {
                            text: is-running ? @tr("Stop") : @tr("Start Game");
                            color: btn-ta.has-hover ? white : (is-running ? #c04040 : #67ab44);
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            font-size: 16px;
                            font-weight: 700;
                        }
                    }

                    btn-ta := TouchArea {
                        clicked => {
                            // if (is-running) {
                            //     InstanceLogic.kill_instance(root.data.id)
                            // } else {
                            //     InstanceLogic.launch_instance(root.data.id)
                            // }
                            if (root.is-valid) {
                                if (is-running) {
                                    InstanceLogic.kill_instance(root.data.id)
                                } else {
                                    InstanceLogic.launch_instance(root.data.id)
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

component AddInstance inherits Rectangle {
    in property <string> text;
    in property <image> icon;
    in property <bool> is_primary: true;

    background: ta.pressed ? (is_primary ? #5a9e3f : #454545) : (ta.has-hover ? (is_primary ? #76bc51 : #3d3d3d) : (is_primary ? #67ab44 : #333333));
    border-radius: 8px;
    height: 36px;
    width: layout.preferred-width + 24px;

    ta := TouchArea {
        clicked => {
            InstanceLogic.new_instance()
        }
    }

    layout := HorizontalLayout {
        spacing: 8px;
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        alignment: center;
        if (root.icon.width > 0): Image {
            width: 20px;
            height: 100%;
            image-fit: contain;
            vertical-alignment: center;
            horizontal-alignment: center;
            source: root.icon;
            colorize: white;
        }
        Text {
            text: root.text;
            color: white;
            font-size: 16px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

component Search inherits Rectangle {
    height: 100%;
    border-radius: AppTheme.radius-lg;
    border-color: #ffffff.with-alpha(0.6);
    border-width: 1px;
    callback _clear-focus();
    _clear-focus => {
        ti.clear-focus();
    }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        s-i := Rectangle {
            width: 24px;
            height: 100%;
            Image {
                source: Assets.search;
                width: 20px;
                height: 20px;
                vertical-alignment: center;
                horizontal-alignment: center;
                image-fit: contain;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            if (!ti.has-focus && ti.text == ""): Text {
                text: @tr("Search instances...");
                color: white.with-alpha(0.5);
                vertical-alignment: center;
                horizontal-alignment: left;
                font-size: 16px;
                width: 100%;
            }

            ti := TextInput {
                text <=> InstanceLogic.search-text;
                width: 100%;
                height: 100%;
                color: white;
                font-size: 16px;
                vertical-alignment: center;
                accepted => {
                    InstanceLogic.search-changed(self.text);
                    root._clear-focus();
                }
                edited => {
                    InstanceLogic.search-changed(self.text);
                }
            }
        }
    }
}

export component Instances inherits Rectangle {
    background: AppTheme.colors.background;
    width: 100%;
    height: 100%;
    property <length> min-card-width: 180px;
    property <int> dynamic-column-count: Math.max(1, Math.floor(self.width / root.min-card-width));
    property <length> calculated-card-width: (self.width - (grid.spacing * (root.dynamic-column-count - 1)) - 40px) / root.dynamic-column-count;

    TouchArea {
        clicked => {
            s-c._clear-focus();
        }
    }

    VerticalLayout {
        Rectangle {
            VerticalLayout {
                padding-top: 20px;
                padding-left: 10px;
                padding-right: 10px;
                padding-bottom: 20px;
                spacing: 10px;
                height: 140px;
                VerticalLayout {
                    height: 50px;
                    HorizontalLayout {
                        alignment: space-between;
                        height: 50px;
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            Image {
                                source: Assets.cube;
                                width: 100%;
                                height: 100%;
                                image-fit: contain;
                            }
                        }

                        Text {
                            text: @tr("My Instances");
                            font-size: 30px;
                            font-weight: 700;
                            color: AppTheme.colors.foreground;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        AddInstance {
                            text: @tr("Create");
                            icon: Assets.plus;
                        }
                    }
                }

                VerticalLayout {
                    height: 50px;
                    s-c := Search { }
                }
            }
        }

        ScrollView {
            viewport-width: parent.width;
            vertical-stretch: 1;
            viewport-height: grid.preferred-height;
            grid := GridLayout {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 20px;
                padding-bottom: 40px;

                for data[i] in InstanceLogic.instance_list: InstanceCard {
                    // width: root.calculated-card-width;
                    visible: data.id != "";
                    width: data.id != "" ? root.calculated-card-width : 0px;
                    height: data.id != "" ? 260px : 0px;
                    // row: Math.floor(i / root.dynamic-column-count);
                    // col: Math.mod(i, root.dynamic-column-count);
                    row: root.dynamic-column-count > 0 ? Math.floor(i / root.dynamic-column-count) : 0;
                    col: root.dynamic-column-count > 0 ? Math.mod(i, root.dynamic-column-count) : 0;
                    data: data;
                }
            }
        }
    }
}
