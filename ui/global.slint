export global PageAccountLogic {
    in-out property <bool> is_logging_in: false;
    in-out property <string> login_url: "";
    in-out property <string> login_status_text: "正在初始化驗證程序...";
    in-out property <bool> is_error: false;
    in-out property <int> selected-index: -1;
    in-out property <[AccountRow]> accounts: [];

    callback login_with_microsoft();
    callback cancel_login();
    callback open_browser_url(string);
    callback add-offline-account();
    callback refresh-account();
    callback remove-account();
    callback set-default-account();
    callback unset-default-account();
    callback manage-appearance();
    callback account-save();

    login_with_microsoft => { debug("Login button clicked"); }
    cancel_login => { debug("Login canceled by user"); }
    open_browser_url(url) => { debug("Opening URL in browser: " + url); }
    add-offline-account => { debug("Add offline account"); }
    refresh-account => { debug("Refresh account"); }
    remove-account => { debug("Remove account"); }
    set-default-account => { debug("Set default account"); }
    unset-default-account => { debug("Unset default account"); }
    manage-appearance => { debug("Manage appearance"); }
    account-save => { debug("Account settings saved"); }
}