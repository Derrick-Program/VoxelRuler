export struct ModData {
    id: string,
    name: string,
    version: string,
    mod_loader: string,
    author: string,
    description: string,
    enabled: bool,
}

export global ModLogic {
    in property <[ModData]> mod_list: [
        {
            id: "1",
            name: "Sodium",
            version: "0.5.8",
            mod_loader: "Fabric",
            author: "CaffeineMC",
            description: "Sodium 是一款針對 Minecraft 客戶端的現代渲染引擎，可大幅提升幀率並修復圖形問題。透過重寫大量渲染代碼，在大多數硬體上都能顯著改善遊戲表現。",
