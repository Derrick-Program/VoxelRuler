import { AppTheme } from "@theme";
import { AccountRow, PageAccountLogic } from "@global";
import { Assets } from "@assets";

export component Avatar inherits Rectangle {
    property <AccountRow> active-account: PageAccountLogic.active-account;

    height: 60px;
    background: AppTheme.colors.secondary.with-alpha(0.3);
    border-radius: AppTheme.radius-lg;
    border-width: 1px;
    border-color: AppTheme.colors.border;

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;
        alignment: start;
        
        Rectangle {
            width: 36px;
            height: 36px;
            background: PageAccountLogic.accounts.length > 0 ? AppTheme.colors.accent : AppTheme.colors.muted;
            border-radius: AppTheme.radius-md;
            clip: true;

            Image {
                source: root.active-account.username == "Guest" ? Assets.user : root.active-account.avatar;
                width: 100%;
                height: 100%;
                image-fit: contain;
            }

            Rectangle {
                width: 12px;
                height: 12px;
                background: root.active-account.status == "Online" ? #22c55e : #6b7280;
                border-radius: 6px;
                border-width: 2px;
                border-color: #1a1a1a;
                x: parent.width - 6px;
                y: parent.height - 6px;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 2px;
            
            Text {
                text: root.active-account.username;
                font-size: 14px;
                font-weight: AppTheme.font-weight-medium;
                color: AppTheme.colors.foreground;
                overflow: elide;
            }

            Text {
                text: root.active-account.authenticator;
                font-size: 10px;
                color: AppTheme.colors.muted-foreground;
                overflow: elide;
            }
        }
    }
}
